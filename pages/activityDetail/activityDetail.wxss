.container {
  width: 100%;
  min-height: 100vh;
  padding: 30rpx;
  background: #f5f5f5;
  box-sizing: border-box;
}
.info-card {
  background: #fff;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
  box-sizing: border-box;
}
.info-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  line-height: 1.4;
}
.info-item {
  display: block;
  font-size: 30rpx;
  color: #666;
  margin-bottom: 12rpx;
  line-height: 1.5;
}
.participant-section {
  background: #fff;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 40rpx;
  box-sizing: border-box;
}
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}
.participant-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.participant-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
}
.participant-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #f0f0f0;
  flex-shrink: 0;
}
.participant-name {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  line-height: 1.4;
}
.empty-tip {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  padding: 40rpx 0;
}
.action-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.action-btn {
  width: 100%;
  height: 90rpx;
  border-radius: 8rpx;
  font-size: 32rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  line-height: normal;
  touch-action: manipulation;
}
.action-btn::after {
  border: none;
  border-radius: 0;
}
.join-btn,
.cancel-btn,
.share-btn,
.remind-btn {
  display: flex;
  align-items: center;
  justify-content: center;
}
.join-btn {
  background: #0066cc;
  color: #fff;
}
.cancel-btn {
  background: #e5e5e5;
  color: #666;
}
.share-btn {
  background: #ff8800;
  color: #fff;
}
.remind-btn {
  background: #00cc66;
  color: #fff;
}
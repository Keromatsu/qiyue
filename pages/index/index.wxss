/* 全局滚动容器 */
.page-scroll {
  width: 100%;
  height: 100vh;
  background: #000;
}
/* ========== 特斯拉风格全屏轮播核心样式 ========== */
.scene-swiper {
  width: 100%;
  height: 100vh;
}
.scene-item {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
}
/* 全屏背景图 */
.scene-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  filter: brightness(0.85);
  z-index: -1;
}
/* 顶部标题区 */
.scene-header {
  position: absolute;
  top: 12%;
  left: 0;
  width: 100%;
  text-align: center;
  padding: 0 30rpx;
  color: #fff;
}
.scene-title {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}
.scene-subtitle {
  display: block;
  font-size: 32rpx;
  font-weight: 300;
  opacity: 0.9;
  margin-bottom: 20rpx;
}
.scene-link {
  display: inline-block;
  font-size: 28rpx;
  color: #fff;
  text-decoration: underline;
  opacity: 0.8;
}
/* 中间核心数据区 - 优化多端适配 */
.stats-section {
  position: absolute;
  bottom: max(42%, 300rpx);
  left: 0;
  width: 100%;
  padding: 0 60rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #fff;
}
.stats-card {
  text-align: center;
  flex: 1;
}
.stats-number {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
}
.stats-label {
  font-size: 26rpx;
  opacity: 0.8;
  font-weight: 300;
}
.stats-note {
  position: absolute;
  bottom: 38%;
  left: 0;
  width: 100%;
  text-align: center;
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  padding: 0 30rpx;
}
/* 底部双按钮区 */
.action-section {
  position: absolute;
  bottom: 8%;
  left: 0;
  width: 100%;
  padding: 0 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
/* 轮播分页器 */
.pagination {
  position: fixed;
  bottom: 22%;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 12rpx;
  z-index: 999;
}
.dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
}
.dot.active {
  background-color: #fff;
  width: 24rpx;
  border-radius: 4rpx;
}
/* ========== 按钮通用样式 ========== */
.btn {
  width: 100%;
  height: 88rpx;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  touch-action: manipulation;
  box-sizing: border-box;
  padding: 0;
  margin: 0;
}
.btn.primary {
  background-color: rgba(255, 255, 255, 0.9);
  color: #171a20;
  font-weight: 600;
}
.btn.secondary {
  background-color: rgba(23, 26, 32, 0.65);
  color: #fff;
  backdrop-filter: blur(8rpx);
}
/* ========== 特斯拉风格全屏视频区 - 优化多端适配 ========== */
.video-section {
  position: relative;
  width: 100%;
  height: min(100vh, 800rpx);
  overflow: hidden;
}
.loop-video {
  width: 100%;
  height: 100%;
}
.video-overlay {
  position: absolute;
  top: 15%;
  left: 0;
  width: 100%;
  text-align: center;
  color: #fff;
  z-index: 2;
  padding: 0 30rpx;
}
.video-title {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}
.video-subtitle {
  display: block;
  font-size: 32rpx;
  font-weight: 300;
  opacity: 0.9;
}
.video-action {
  position: absolute;
  bottom: 8%;
  left: 0;
  width: 100%;
  padding: 0 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
/* ========== 补充内容区 ========== */
.extra-content {
  padding: 80rpx 30rpx;
  background-color: #171a20;
  color: #fff;
}
.extra-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 50rpx;
}
.feature-list {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
}
.feature-item {
  display: flex;
  align-items: center;
  gap: 15rpx;
  font-size: 30rpx;
  padding: 0 20rpx;
}
.feature-icon {
  font-size: 32rpx;
}